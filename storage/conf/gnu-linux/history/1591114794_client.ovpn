##Home
client
dev tun
proto udp
remote xvpn.ddnss.org 1194
resolv-retry infinite
cipher AES-256-CBC
redirect-gateway

# Keys
# Identity
key-direction 1
remote-cert-tls server
auth-user-pass
auth-nocache

# Security
nobind
persist-key
persist-tun
comp-lzo
verb 3

# DNS
script-security 2
up ./update-resolv.sh
down ./update-resolv.sh

# Proxy ?
# http-proxy cache.univ.fr 3128
